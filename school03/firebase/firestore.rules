rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function getRole() {
      return isSignedIn() ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : null;
    }
    function isAdmin() { return getRole() == 'admin'; }
    function isLehrer() { return getRole() == 'lehrer'; }
    function isSchueler() { return getRole() == 'schueler'; }
    function unterrichtetKlasse(klasseId) {
      return isLehrer() && klasseId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.klassenIds;
    }

    match /users/{userId} {
      allow read: if isAdmin() || request.auth.uid == userId;
      allow write: if isAdmin();
    }
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /klassen/{klasseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /termine/{terminId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
      match /anwesenheit/{schuelerId} {
        allow read: if isAdmin() || unterrichtetKlasse(klasseId) || (isSchueler() && request.auth.uid == schuelerId);
        allow update: if isAdmin() || (isSchueler() && request.auth.uid == schuelerId &&
                       request.resource.data.keys().hasOnly(['name','email','abgemeldeteTermine','aktualisiertAm']));
        allow create: if isAdmin() || (isSchueler() && request.auth.uid == schuelerId);
      }
    }
    match /aenderungen/{id} {
      allow read: if isAdmin() || isLehrer() || isSchueler();
      allow write: if isAdmin();
    }
  }
}
